# Google Cloud OAuth (installed app redirect for localhost in oauth-setup script)
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REFRESH_TOKEN=

# Must match Authorized redirect URIs exactly for the oauth helper (default below)
GOOGLE_REDIRECT_URI=http://127.0.0.1:42813/oauth2callback

# Target folder ID from the Drive folder URL (.../folders/THIS_PART)
GOOGLE_DRIVE_FOLDER_ID=

# Optional overrides
BILLING_LABEL=Billing
PROCESSED_LABEL=Billing Processed
MAX_MESSAGES_PER_RUN=10
# false = also save JPEG/PNG (etc.) attachments — needed if invoices arrive as images
REQUIRE_PDF_ONLY=true

# ---- Drive placement (pick ONE organizational mode) --------
# empty | iso_month | none | fy_trimesters_fr (aliases: fy_trimestres_fr, fr_fy_trimesters, fr_trimestres).
# Empty keeps legacy ISO via ORGANIZE_BY_MONTH=true by default.
# fy_trimesters_fr + FY_LEAF_COUNTER=fiscal → n cycles 1=AVRIL … 12=MARS under Trimestre {{t}} folders.
DRIVE_ORGANIZATION=

# ----- Mode: ISO yyyy-MM buckets (ignored after fy_trimesters_fr) -----
ORGANIZE_BY_MONTH=true
DRIVE_MONTH_FOLDER_STYLE=yyyy-mm
DRIVE_SUBFOLDER_TIME_ZONE=UTC
DRIVE_SUBFOLDER_LOCALE=en-US

# ----- Mode: FY trimesters (April→March FY) -----
FY_TRIMESTRE_FOLDER_TEMPLATE=Trimestre {{t}}
FY_MONTH_LEAF_FOLDER_TEMPLATE={{n}}. {{MONTH_FR}}
# fiscal (default): n = 1..12 across FY | quarter: resets 1..3 each trimester
FY_LEAF_COUNTER=fiscal
FY_SUBFOLDER_TIME_ZONE=UTC

# ---- Routing date (folder + filename prefix) -----------------
# gmail (default): use Gmail internalDate (when the message was stored).
# invoice: parse each attachment — PDF (embedded text → Document AI), JPEG/PNG (Document AI only)
# Unsupported types → Gmail time. Configure Document AI for scans and images.
ROUTING_DATE_SOURCE=gmail

# Optional: Document AI Invoice Parser for scanned PDFs (full processor resource name from Cloud Console).
DOCUMENT_AI_PROCESSOR_NAME=
# DOCUMENT_AI_LOCATION=eu
# Service account JSON (Document AI API enabled on the project). OAuth refresh token alone is not enough for REST Document AI.
# GOOGLE_APPLICATION_CREDENTIALS_JSON=

# Vercel: set CRON_SECRET in dashboard; Vercel Cron sends Authorization: Bearer <CRON_SECRET>
CRON_SECRET=
