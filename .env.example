# Google Cloud OAuth (installed app redirect for localhost in oauth-setup script)
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REFRESH_TOKEN=

# Must match Authorized redirect URIs exactly for the oauth helper (default below)
GOOGLE_REDIRECT_URI=http://127.0.0.1:42813/oauth2callback

# Target folder ID from the Drive folder URL (.../folders/THIS_PART)
GOOGLE_DRIVE_FOLDER_ID=

# Optional overrides
BILLING_LABEL=Billing
PROCESSED_LABEL=Billing Processed
MAX_MESSAGES_PER_RUN=10
REQUIRE_PDF_ONLY=true

# Vercel: set CRON_SECRET in dashboard; Vercel Cron sends Authorization: Bearer <CRON_SECRET>
CRON_SECRET=
